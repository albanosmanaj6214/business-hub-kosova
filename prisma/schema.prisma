generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INACTIVE
}

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum NotificationType {
  GRANT
  FAIR
  GUIDE
  SYSTEM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String?
  companyName     String?
  sector          String?
  language        String    @default("sq")
  role            Role      @default(USER)
  interests       String[]  @default([])
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscription    Subscription?
  notifications   Notification[]
  bookings        ConsultationBooking[]
  accounts        Account[]
  sessions        Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Grant {
  id           String   @id @default(cuid())
  title        String
  titleSq      String?
  description  String   @db.Text
  descriptionSq String? @db.Text
  provider     String
  amount       String?
  currency     String   @default("EUR")
  deadline     DateTime?
  eligibility  String?  @db.Text
  url          String?
  country      String?
  sectors      String[] @default([])
  tags         String[] @default([])
  isActive     Boolean  @default(true)
  scrapedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([deadline])
  @@index([isActive])
}

model TradeFair {
  id           String   @id @default(cuid())
  name         String
  nameSq       String?
  description  String?  @db.Text
  descriptionSq String? @db.Text
  location     String
  country      String
  startDate    DateTime
  endDate      DateTime
  website      String?
  sectors      String[] @default([])
  tags         String[] @default([])
  isActive     Boolean  @default(true)
  scrapedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([startDate])
  @@index([isActive])
}

model ExportGuide {
  id           String   @id @default(cuid())
  title        String
  titleSq      String?
  content      String   @db.Text
  contentSq    String?  @db.Text
  country      String
  sectors      String[] @default([])
  tags         String[] @default([])
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([country])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  titleSq   String?
  message   String           @db.Text
  messageSq String?          @db.Text
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model ConsultationBooking {
  id          String        @id @default(cuid())
  userId      String
  date        DateTime
  time        String
  topic       String
  notes       String?       @db.Text
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScraperLog {
  id        String   @id @default(cuid())
  type      String
  status    String
  message   String?  @db.Text
  itemsFound Int     @default(0)
  duration  Int?
  createdAt DateTime @default(now())
}
